{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/index.schema.json",
  "title": "IndexArtifact",
  "description": "Trimmed metadata records for result cards and item page links. Only fields the card renders, empty values omitted.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "items"],
  "properties": {
    "version": { "const": 2 },
    "generated_at": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["filename", "image_path", "item_url"],
        "properties": {
          "filename": { "type": "string", "minLength": 1 },
          "image_path": { "type": "string", "minLength": 1 },
          "item_url": { "type": "string", "minLength": 1 },
          "thumb_path": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "active_years": { "type": "string", "minLength": 1 },
          "printers": { "type": "string", "minLength": 1 },
          "publishers": { "type": "string", "minLength": 1 },
          "website": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
